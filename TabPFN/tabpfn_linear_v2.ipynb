      },
      "outputs": [],
      "source": [
        "def split_data(X, Y, p = 0.8, seed = 123456):\n",
        "    X_train, X_test, Y_train, Y_test = train_test_split(X, Y, train_size = p, random_state = seed)\n",
        "    return X_train, X_test, Y_train, Y_test"
      ]
    },
    {
      "cell_type": "code",
      "execution_count": null,
      "metadata": {
        "id": "R2Snpf5J1601"
      },
      "outputs": [],
      "source": [
        "def performance_eval(Y_pred, Y_test):\n",
        "    Y_pred = np.array(Y_pred)\n",
        "    Y_test = np.array(Y_test)\n",
        "    MAE = np.mean(np.abs(Y_pred - Y_test))\n",
        "    RMSE = np.sqrt(np.mean((Y_pred - Y_test)**2))\n",
        "    MAPE = np.mean(np.abs(Y_test - Y_pred) / ((np.abs(Y_test) + np.abs(Y_pred)) / 2)) * 100\n",
        "\n",
        "    #accuracy = np.mean(Y_pred == Y_test) * 100\n",
        "\n",
        "    return MAE, RMSE, MAPE"
      ]
    },
